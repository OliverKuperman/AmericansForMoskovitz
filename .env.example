# Server
PORT=3000
SITE_URL=https://yourdomain.com

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moskovitz_petition
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Set to "true" only when connecting to a remote DB over SSL
DB_SSL=false

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used to send email verification links when someone submits the petition.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com/apppasswords and create an App Password.
#   3. Set SMTP_USER to your Gmail address.
#   4. Set SMTP_PASS to the generated 16-character App Password.
#
# Other providers: adjust SMTP_HOST/PORT/SECURE accordingly.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="Americans for Moskovitz" <your-gmail@gmail.com>
